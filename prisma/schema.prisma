// ─────────────────────────────────────────────────────────────────────
// Connexion PostgreSQL via la variable DATABASE_URL du .env
// ─────────────────────────────────────────────────────────────────────
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═════════════════════════════════════════════════════════════════════
// ENUMS
// ═════════════════════════════════════════════════════════════════════

enum UserRole {
  student
  teacher
  agent
  admin
}

enum AgentType {
  agent_administratif
  technicien
  responsable_labo
  bibliothecaire
  securite
  autre
}

enum MentionType {
  ALL // @tous
  ROLE // @technicien, @admin, @enseignant
  GROUP // @ING_A1_G1
  USER // @Ahmed_Ben
}

// ═════════════════════════════════════════════════════════════════════
// TABLE USERS — tous les rôles dans une seule table
// ═════════════════════════════════════════════════════════════════════

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  firstName String
  lastName  String
  username  String   @unique // utilisé pour les @mentions (@Ahmed_Ben)
  role      UserRole

  // Champs spécifiques selon le rôle
  agentType      AgentType? // uniquement si role == agent
  studentGroup   String? // ex: 'ING_A1_G1' (uniquement si role == student)
  department     String? // ex: 'informatique'
  profilePicture String?
  isActive       Boolean    @default(true)
  refreshToken   String?

  // Relations
  taughtSchedules   Schedule[]       @relation("TeacherSchedules")
  publishedNews     News[]           @relation("AuthorNews")
  uploadedMaterials CourseMaterial[] @relation("TeacherMaterials")
  sentMessages      Message[]        @relation("SenderMessages")
  createdThreads    Thread[]         @relation("CreatorThreads")
  notifications     Notification[]   @relation("RecipientNotifications")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

// ═════════════════════════════════════════════════════════════════════
// TABLE SCHEDULE — emplois du temps
// ═════════════════════════════════════════════════════════════════════

model Schedule {
  id           String  @id @default(uuid())
  subject      String // matière
  room         String // salle
  dayOfWeek    Int // 0=Lundi, 1=Mardi, 2=Mercredi, 3=Jeudi, 4=Vendredi
  startTime    String // ex: '08:00'
  endTime      String // ex: '10:00'
  studentGroup String // ex: 'ING_A1_G1'
  semester     String? // ex: 'S1'
  type         String? // ex: 'cours', 'td', 'tp'

  teacherId String?
  teacher   User?   @relation("TeacherSchedules", fields: [teacherId], references: [id])

  createdAt DateTime @default(now())

  @@map("schedules")
}

// ═════════════════════════════════════════════════════════════════════
// TABLE NEWS — actualités
// ═════════════════════════════════════════════════════════════════════

model News {
  id          String  @id @default(uuid())
  title       String
  content     String
  imageUrl    String?
  isPinned    Boolean @default(false)
  targetGroup String? // null = tous, sinon ex: 'ING_A1_G1'

  authorId String
  author   User   @relation("AuthorNews", fields: [authorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("news")
}

// ═════════════════════════════════════════════════════════════════════
// TABLE COURSE_MATERIALS — supports de cours
// ═════════════════════════════════════════════════════════════════════

model CourseMaterial {
  id          String  @id @default(uuid())
  title       String
  description String?
  fileName    String // nom original du fichier
  filePath    String // chemin stocké sur le serveur
  subject     String // matière concernée
  targetGroup String // ex: 'ING_A1_G1' ou 'all'
  semester    String?

  teacherId String
  teacher   User   @relation("TeacherMaterials", fields: [teacherId], references: [id])

  uploadedAt DateTime @default(now())

  @@map("course_materials")
}

// ═════════════════════════════════════════════════════════════════════
// TABLE FORUM THREADS — sujets du forum
// ═════════════════════════════════════════════════════════════════════

model Thread {
  id        String  @id @default(uuid())
  title     String
  isPrivate Boolean @default(false)

  creatorId String
  creator   User   @relation("CreatorThreads", fields: [creatorId], references: [id])

  messages Message[]

  createdAt DateTime @default(now())

  @@map("forum_threads")
}

// ═════════════════════════════════════════════════════════════════════
// TABLE MESSAGES — messages du forum
// ═════════════════════════════════════════════════════════════════════

model Message {
  id            String  @id @default(uuid())
  content       String
  attachmentUrl String?

  senderId String
  sender   User   @relation("SenderMessages", fields: [senderId], references: [id])

  threadId String
  thread   Thread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  // Réponse à un autre message
  replyToId String?
  replyTo   Message?  @relation("MessageReplies", fields: [replyToId], references: [id])
  replies   Message[] @relation("MessageReplies")

  mentions Mention[]

  createdAt DateTime @default(now())

  @@map("forum_messages")
}

// ═════════════════════════════════════════════════════════════════════
// TABLE MENTIONS — résolution des @tags dans les messages
// ═════════════════════════════════════════════════════════════════════

model Mention {
  id          String      @id @default(uuid())
  type        MentionType
  targetValue String // ex: 'technicien', 'ING_A1_G1', 'Ahmed_Ben', 'tous'

  messageId String
  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@map("mentions")
}

// ═════════════════════════════════════════════════════════════════════
// TABLE NOTIFICATIONS
// ═════════════════════════════════════════════════════════════════════

model Notification {
  id     String  @id @default(uuid())
  title  String
  body   String
  isRead Boolean @default(false)
  link   String? // lien vers le thread/message concerné

  recipientId String
  recipient   User   @relation("RecipientNotifications", fields: [recipientId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@map("notifications")
}
